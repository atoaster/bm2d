#!/usr/bin/env bash
set -euo pipefail

BM2D_BACKEND="${BM2D_BACKEND:-claude}"

if [[ $# -eq 0 || "$1" == "-h" || "$1" == "--help" ]]; then
    echo "Usage: bm2d '<describe what you want to do>'"
    echo "Example: bm2d 'convert all videos to h265'"
    echo ""
    echo "Backends (set BM2D_BACKEND env var):"
    echo "  claude  - Claude Code CLI (default, uses your Claude subscription)"
    echo "  openai  - OpenAI API (requires OPENAI_API_KEY)"
    echo "  gemini  - Google Gemini API (requires GEMINI_API_KEY)"
    exit 0
fi

query="$*"
dir_context="Current directory: $(pwd)"$'\n'

entries=$(ls -1 2>/dev/null | head -200)
if [[ -n "$entries" ]]; then
    count=$(echo "$entries" | wc -l)
    dir_context+="Files/directories ($count entries):"$'\n'"$entries"
else
    dir_context+="Directory is empty."
fi

if git rev-parse --is-inside-work-tree &>/dev/null; then
    dir_context+=$'\n'"Inside a git repository."
fi

system_prompt="You are a bash one-liner generator. You MUST output ONLY a single bash one-liner that can be directly executed in a bash terminal. Your entire response must be valid bash. Rules:
- No explanations, no comments, no markdown, no code fences, no English text whatsoever.
- Only output the command itself. Nothing before it, nothing after it.
- Always prefer one-liners using pipes, semicolons, &&, subshells, or for loops on a single line.
- If the request is impossible or nonsensical, output: echo \"Error: cannot generate command\"
- Use the actual files and extensions present in the directory context below."

user_prompt="<directory_context>
${dir_context}
</directory_context>

<request>
${query}
</request>"

# -- Backend functions --

call_claude() {
    local full_prompt="${system_prompt}

${user_prompt}"
    claude --print --model claude-sonnet-4-6 "$full_prompt"
}

call_openai() {
    if [[ -z "${OPENAI_API_KEY:-}" ]]; then
        echo "Error: OPENAI_API_KEY is not set" >&2
        exit 1
    fi
    local payload
    payload=$(jq -n \
        --arg sys "$system_prompt" \
        --arg usr "$user_prompt" \
        '{
            model: "gpt-4o",
            max_tokens: 1024,
            messages: [
                {role: "system", content: $sys},
                {role: "user", content: $usr}
            ]
        }')
    curl -s https://api.openai.com/v1/chat/completions \
        -H "Authorization: Bearer ${OPENAI_API_KEY}" \
        -H "Content-Type: application/json" \
        -d "$payload" | jq -r '.choices[0].message.content'
}

call_gemini() {
    if [[ -z "${GEMINI_API_KEY:-}" ]]; then
        echo "Error: GEMINI_API_KEY is not set" >&2
        exit 1
    fi
    local payload
    payload=$(jq -n \
        --arg sys "$system_prompt" \
        --arg usr "$user_prompt" \
        '{
            system_instruction: {parts: [{text: $sys}]},
            contents: [{role: "user", parts: [{text: $usr}]}],
            generationConfig: {maxOutputTokens: 1024}
        }')
    curl -s "https://generativelanguage.googleapis.com/v1beta/models/gemini-2.5-flash:generateContent?key=${GEMINI_API_KEY}" \
        -H "Content-Type: application/json" \
        -d "$payload" | jq -r '.candidates[0].content.parts[0].text'
}

# -- Spinner --

spinner_frames=('в†Л' 'в†Щ' 'в†є' 'в†Є' 'в†Љ' 'в†і' 'в†¶' 'в†І' 'в†З' 'в†П')
spin() {
    local i=0
    while true; do
        printf '\r\033[36m%s \033[0m\033[2mthinking...\033[0m' "${spinner_frames[i++ % ${#spinner_frames[@]}]}" >&2
        sleep 0.08
    done
}

spin &
spinner_pid=$!
trap 'kill "$spinner_pid" 2>/dev/null; printf "\r\033[K" >&2' EXIT

case "$BM2D_BACKEND" in
    claude) result=$(call_claude) ;;
    openai) result=$(call_openai) ;;
    gemini) result=$(call_gemini) ;;
    *)
        kill "$spinner_pid" 2>/dev/null
        printf '\r\033[K' >&2
        echo "Error: unknown backend '${BM2D_BACKEND}'. Use: claude, openai, or gemini" >&2
        exit 1
        ;;
esac

kill "$spinner_pid" 2>/dev/null
wait "$spinner_pid" 2>/dev/null
printf '\r\033[K' >&2
trap - EXIT

echo "$result"
